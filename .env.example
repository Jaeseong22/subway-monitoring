SUBWAY_API_KEY=your_seoul_open_api_key
SUBWAY_API_KEY_SECONDARY=optional_second_key

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id

# 비워두면 관리자 계정이 생성되지 않아 /admin 대시보드에 로그인할 수 없다.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_NAME=관리자

# 이상탐지 실행 주기. 기본은 5분 상시 관측.
# RUN_TIMES를 지정하면 고정 시각 모드로 바뀌며 그 시각 외에는 관측 공백이 생긴다.
RUN_INTERVAL_MINUTES=5
RUN_TIMES=
RUN_ON_STARTUP=true
MISFIRE_GRACE_SECONDS=3600
LOOKBACK_MINUTES=10
ANOMALY_INDEX=subway-anomaly-results
LOG_INDEX_PATTERN=subway-logs-*
OFF_HOURS_START=02:00
OFF_HOURS_END=05:00
TZ=Asia/Seoul

# 이상탐지 판정 튜닝 (미설정 시 아래 기본값)
# 연속 N회 감지되어야 확정 알람으로 승격 (플래핑 방지). 1이면 즉시 알람.
ANOMALY_CONSECUTIVE_N=2
# 배수 게이트와 함께 적용되는 z-score 게이트
Z_SCORE_WARN=2.0
Z_SCORE_CRIT=3.0
LATENCY_WARN_RATIO=1.5
LATENCY_CRIT_RATIO=2.0
TRAFFIC_SPIKE_RATIO=2.0
# 기준선이 없을 때의 절대 가드레일 (총 요청수가 아니라 req/s 기준)
TRAFFIC_RPS_WARN=20
TRAFFIC_RPS_CRIT=50
MIN_BASELINE_SAMPLES=5

# 자동 대응 (감지 → 제안 → 승인 → 실행 → 검증 → 롤백)
REMEDIATION_INDEX=subway-remediation-actions
REMEDIATION_ENABLED=true
# true로 두면 관리자 승인 없이 바로 실행 대기 상태가 된다. 기본은 human-in-the-loop.
REMEDIATION_AUTO_APPROVE=false
REMEDIATION_SERVICE=backend
REMEDIATION_MIN_REPLICAS=1
REMEDIATION_MAX_REPLICAS=4
# 조치 직후에는 지표가 안정될 시간이 필요하다(연속 확장 방지).
REMEDIATION_COOLDOWN_MINUTES=15
# 실행 후 이 시간이 지나면 지표를 다시 보고 성패를 판정한다.
REMEDIATION_VERIFY_AFTER_MINUTES=10
REMEDIATION_EXPIRE_AFTER_MINUTES=60
# 실행이 이 시간 내에 완료되지 않으면 워커 중단으로 보고 정리(파이프라인 영구 정지 방지)
REMEDIATION_EXECUTE_TIMEOUT_MINUTES=15
REMEDIATION_SCALE_IN_AFTER_NORMAL_RUNS=6
# 워커 전용: true여야 실제로 docker compose --scale을 실행한다. 기본은 dry-run.
REMEDIATION_EXECUTE=false
REMEDIATION_POLL_SECONDS=30

DB_HOST=localhost
DB_PORT=3307
DB_NAME=subway_monitoring
DB_USER=subway
DB_PASSWORD=subway123
